# ============================================================
# Inhouse Internships 2.0 — Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate secrets:
#   JWT_SECRET:    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   ADMIN_SECRET:  node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ============================================================


# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production

PORT=5000

# Set to a specific IP, or 'auto' to detect the local network IP automatically
HOST_IP=auto


# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/inhouse_internships

# If MongoDB is on a different host, replace AUTO_IP with your server's IP:
# MONGO_URI=mongodb://192.168.1.100:27017/inhouse_internships


# ── Security ─────────────────────────────────────────────────
# REQUIRED: Generate a strong random secret (min 32 chars)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

JWT_EXPIRES_IN=1d
JWT_ISSUER=ii2-backend

# bcrypt cost factor (10 = fast/dev, 12 = balanced/prod, 14 = slow/high-security)
BCRYPT_SALT_ROUNDS=12


# ── Rate Limiting ─────────────────────────────────────────────
# Global rate limit (all routes): 1000 requests per 15 minutes per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
# Note: Auth routes (/login, /forgot-password, etc.) have a separate
# strict limit of 10 requests per 15 minutes (configured in authRateLimit.js)


# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for production
# Leave blank in development (all localhost origins are allowed)
CORS_ORIGINS=https://internship.adityauniversity.in,http://internship.adityauniversity.in


# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=your-email@yourdomain.com


# ── OTP ──────────────────────────────────────────────────────
OTP_TTL_MINUTES=10
REQUIRE_REGISTRATION_OTP=true


# ── University Domain Config ──────────────────────────────────
# Primary domain (used for email suffix toggle on login/register pages)
UNIVERSITY_EMAIL_DOMAIN=@adityauniversity.in

# All accepted domains (comma-separated, used for login ID strip logic)
UNIVERSITY_EMAIL_DOMAINS=@adityauniversity.in,@ace.edu.in


# ── User Import ───────────────────────────────────────────────
# Default password assigned to bulk-imported users (they should change it)
# Leave blank to require an explicit password per import row
DEFAULT_IMPORTED_USER_PASSWORD=


# ── Analytics Cache ───────────────────────────────────────────
# How long to cache university analytics results (milliseconds)
# Default: 120000 (2 minutes)
ANALYTICS_CACHE_TTL_MS=120000
