{
  "name": "backend",
  "version": "1.0.0",
  "description": "Inhouse Internships 2.0 — Backend API",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "predev": "powershell -Command \"$pids = (netstat -ano | Select-String ':5000\\s+' | ForEach-Object { ($_ -split '\\s+')[-1] } | Where-Object { $_ -ne '0' }) | Sort-Object -Unique; if ($pids) { foreach ($p in $pids) { Stop-Process -Id $p -Force -ErrorAction SilentlyContinue } }\"",
    "dev": "nodemon src/server.js",
    "check-env": "node check_settings.js",
    "db:backup": "node scripts/duplicate_db.js",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.1.6",
    "multer": "^2.1.0",
    "nodemailer": "^6.9.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}